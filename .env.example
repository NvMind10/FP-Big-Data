# Salin file ini menjadi ".env" lalu isi nilai di bawah dengan kredensial Anda sendiri.
# JANGAN commit file ".env" (sudah dimasukkan ke .gitignore).

# MongoDB Atlas connection string (dari Database & Storage Engineer tim)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?appName=Cluster0

# Path lokal ke folder hasil training model IndoBERT (lihat ml-nlp/)
MODEL_PATH=./scamshield_model_final

# Konfigurasi Kafka (opsional, default sudah sesuai setup lokal)
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC=scamshield_stream

# --- Opsional: jika Anda juga memindahkan kredensial Telegram di ml-nlp/AI_SCAMSHIELD.ipynb ke .env ---
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
